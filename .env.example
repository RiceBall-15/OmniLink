# Database Configuration
DATABASE_URL=postgres://im_chat:password@localhost:5432/im_chat
REDIS_URL=redis://:password@localhost:6379/0
MONGODB_URL=mongodb://admin:password@localhost:27017/im_chat?authSource=admin

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AI API Keys (Optional - for AI service)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key

# Service Ports
IM_GATEWAY_PORT=8001
IM_API_PORT=8002
AI_SERVICE_PORT=8003
USER_SERVICE_PORT=8004
FILE_SERVICE_PORT=8005
USAGE_SERVICE_PORT=8006
PUSH_SERVICE_PORT=8007
CONFIG_SERVICE_PORT=8008
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Message Queue
KAFKA_BROKERS=localhost:9092

# API Keys - OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# API Keys - Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# API Keys - Google
GOOGLE_API_KEY=your_google_api_key_here

# API Keys - Domestic Models
BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_SECRET_KEY=your_baidu_secret_key_here
QWEN_API_KEY=your_qwen_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here

# Security
JWT_SECRET=your-jwt-secret-key-here-please-change-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Application Settings
APP_ENV=development
APP_LOG_LEVEL=debug

# Server Ports
IM_GATEWAY_PORT=8080
IM_API_PORT=8081
AI_SERVICE_PORT=8082
USER_SERVICE_PORT=8083
FILE_SERVICE_PORT=8084
USAGE_SERVICE_PORT=8085
PUSH_SERVICE_PORT=8086
CONFIG_SERVICE_PORT=8087

# Limits
MAX_WEBSOCKET_CONNECTIONS=10000
MAX_UPLOAD_FILE_SIZE=10485760
RATE_LIMIT_PER_MINUTE=100

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin