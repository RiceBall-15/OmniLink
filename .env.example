# OmniLink 环境变量配置
# 复制此文件为 .env 并修改配置
# cp .env.example .env

# ============================================
# 应用环境
# ============================================
APP_ENV=production
RUST_LOG=info

# ============================================
# 数据库配置 (PostgreSQL)
# ============================================
POSTGRES_USER=omnilink
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=omnilink
POSTGRES_PORT=5432

# ============================================
# Redis 配置
# ============================================
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# ============================================
# MinIO 对象存储
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_BUCKET=omnilink
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================
# JWT 配置
# ============================================
# 必须设置，至少32字符
JWT_SECRET=your_jwt_secret_key_here_at_least_32_chars

# ============================================
# AI 服务 API Keys（可选）
# ============================================
OPENAI_API_KEY=
QWEN_API_KEY=
ZHIPU_API_KEY=
ERNIE_API_KEY=

# ============================================
# 服务端口配置
# ============================================
IM_API_PORT=8002
IM_GATEWAY_PORT=3002
AI_SERVICE_PORT=8003
USER_SERVICE_PORT=8004
USAGE_SERVICE_PORT=8006
FILE_SERVICE_PORT=8007
CONFIG_SERVICE_PORT=8008
PUSH_SERVICE_PORT=3005

# ============================================
# Nginx 反向代理
# ============================================
HTTP_PORT=80
HTTPS_PORT=443

# ============================================
# 监控配置 (Grafana)
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password_here
GRAFANA_PORT=3000

# ============================================
# pgAdmin 配置（仅开发环境）
# ============================================
PGADMIN_EMAIL=admin@omnilink.dev
PGADMIN_PASSWORD=admin
