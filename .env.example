# OmniLink Docker 环境变量配置
# 复制此文件为 .env 并修改配置

# ============================================
# 数据库配置
# ============================================
POSTGRES_PASSWORD=your_secure_password_here

# ============================================
# Redis 配置
# ============================================
# Redis 默认无密码，生产环境建议设置密码

# ============================================
# MinIO 对象存储
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your_jwt_secret_key_here_at_least_32_chars

# ============================================
# pgAdmin 配置（仅开发环境）
# ============================================
PGADMIN_EMAIL=admin@omnilink.dev
PGADMIN_PASSWORD=admin

# ============================================
# 日志级别
# ============================================
RUST_LOG=info

# ============================================
# 服务器配置
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GATEWAY_PORT=8081
